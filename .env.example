# ─── Supabase ────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — NEVER prefix with NEXT_PUBLIC_, never import in
# anything under /app or /components. Only used by trusted server-only
# scripts (e.g. a Vercel Cron route calling prune_rate_log()).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used by `npm run supabase:gen-types` to regenerate types/database.ts
SUPABASE_PROJECT_ID=your-project-ref

# ─── Google OAuth ───────────────────────────────────────────────────────
# Configure the actual client ID/secret in the Supabase Dashboard under
# Authentication → Providers → Google — not here. Supabase handles the
# OAuth handshake server-side; the app only needs the URL/anon key above
# plus the redirect URL registered in both Google Cloud Console and
# Supabase: https://your-project-ref.supabase.co/auth/v1/callback

# ─── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
